# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# https://docs.composio.dev
COMPOSIO_API_KEY=****

# https://console.supermemory.ai
SUPERMEMORY_API_KEY=****


# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=****
TELEGRAM_BOT_USERNAME=****
# Any random string — set as secret when registering webhook
TELEGRAM_WEBHOOK_SECRET=****


# Vercel Cron — generate with: openssl rand -base64 32
CRON_SECRET=****
